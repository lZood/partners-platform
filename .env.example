# ============================================================================
# Partners Platform — Environment Variables
# Copy this file and rename to .env.local (for local dev) or set in Dokploy
# ============================================================================

# ── Supabase (Required) ─────────────────────────────────────────────────────
# These two are PUBLIC and get inlined at build time (needed as Build Args too)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# This is SECRET — only used server-side, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
