# ============================================================================
# Partners Platform — Environment Variables
# Copy this file and rename to .env.local (for local dev) or set in Dokploy
# ============================================================================

# ── Supabase (Required) ─────────────────────────────────────────────────────
# These two are PUBLIC and get inlined at build time (needed as Build Args too)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# This is SECRET — only used server-side, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── App URL (Required for production) ──────────────────────────────────────
# Used for invitation emails redirect. Set to your actual domain/IP.
# Without this, invitation links may point to localhost.
NEXT_PUBLIC_APP_URL=http://your-server-ip:3000

# ── SMTP (Required for sending invitation emails) ─────────────────────────
# Your own SMTP server (Mailu, Postfix, etc.) for sending emails directly
# instead of through Supabase's built-in email service.
SMTP_HOST=mail.box-build.com
SMTP_PORT=587
SMTP_USER=admin@box-build.com
SMTP_PASS=your-smtp-password
SMTP_FROM=admin@box-build.com
